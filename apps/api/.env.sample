# =============================================================================
# apps/api — NestJS REST API
# All values below are RUNTIME env (read at container start, not baked at build).
# In the deployment repo these are supplied to the `api` service via docker
# compose (env_file / environment). Copy to `apps/api/.env` for local dev.
# =============================================================================

# --- Database ---------------------------------------------------------------
# MongoDB connection string.
#   Local dev            : mongodb://localhost:27017/dms-platform
#   Self-hosted (compose): mongodb://<user>:<pass>@mongo:27017/dms-platform?authSource=admin
#   Atlas                : mongodb+srv://<user>:<pass>@cluster.mongodb.net/dms-platform?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/dms-platform

# --- Auth (JWT) -------------------------------------------------------------
# MUST be a long, random secret in production. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Server -----------------------------------------------------------------
# Port the API listens on inside the container. Nginx proxies
# api-dms.sumedhsakya.com.np -> this port. Default 3333.
PORT=3333

# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed browser origins (NO trailing slash, NO spaces).
# Must include the public web + bo origins so their fetch/axios calls succeed.
#   Local dev  : http://localhost:3000,http://localhost:4201
#   Production : https://dms.sumedhsakya.com.np,https://bo-dms.sumedhsakya.com.np
CORS_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:4201
