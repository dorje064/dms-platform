# =============================================================================
# apps/web — Next.js 16 public site (dms.sumedhsakya.com.np)
#
# IMPORTANT: NEXT_PUBLIC_* vars are BAKED INTO THE BUILD. They are inlined at
# `next build` time and cannot be changed at container runtime. In CI this must
# be passed as a Docker build ARG, not just a runtime env, or the browser bundle
# and next.config.js image `remotePatterns` will point at the wrong host.
# Copy to `apps/web/.env.local` for local dev.
# =============================================================================

# Base URL of the API, INCLUDING the /api global prefix.
# Also used by next.config.js to whitelist the upload host for next/image.
#   Local dev  : http://localhost:3333/api
#   Production : https://api-dms.sumedhsakya.com.np/api
NEXT_PUBLIC_API_URL=http://localhost:3333/api
