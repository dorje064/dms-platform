# =============================================================================
# apps/bo — Vite + React backoffice SPA (bo-dms.sumedhsakya.com.np)
#
# IMPORTANT: VITE_* vars are BAKED INTO THE BUILD. Vite inlines them at build
# time into the static bundle; they cannot be changed at container runtime.
# In CI this must be passed as a Docker build ARG, not just a runtime env.
# Copy to `apps/bo/.env` for local dev.
# =============================================================================

# Base URL of the API, INCLUDING the /api global prefix.
#   Local dev  : http://localhost:3333/api
#   Production : https://api-dms.sumedhsakya.com.np/api
VITE_API_BASE_URL=http://localhost:3333/api
