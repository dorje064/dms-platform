# Per-image tags (short commit SHA) — updated automatically by the build
# workflow's `bump` job (.github/workflows/build.yml on the main branch).
# docker-compose.yml interpolates these:  ghcr.io/.../dms-api:${API_IMAGE_TAG}
#
# The values below are BOOTSTRAP PLACEHOLDERS. Before the first deploy, run the
# "Build & Push" workflow with build_all=true so all three are set to real,
# pullable short-SHA tags (a placeholder tag will fail `docker compose pull`).
API_IMAGE_TAG=e6ad5fb
WEB_IMAGE_TAG=e6ad5fb
BO_IMAGE_TAG=e6ad5fb
